/* ============================================================
 * operator_registry.def — X-macro 算子注册表
 *
 * 新增算子时只需在此文件添加一行，无需修改 operator_init.c。
 * 格式：
 *   REGISTER_CPU(fn)  — CPU 算子注册函数
 *   REGISTER_CUDA(fn) — CUDA 算子注册函数（.cu 文件中的 extern "C" 函数）
 * ============================================================ */

/* ---- CPU 算子 ---- */
REGISTER_CPU(register_relu_f32)
REGISTER_CPU(register_matmul_f32)
REGISTER_CPU(register_conv2d_f32)
